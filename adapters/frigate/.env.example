# Copy to .env (gitignored) and adjust. See docs/SETUP.md.
#
# Recommended for a trusted-LAN companion: Frigate's port 5000 under /api is the
# network-reachable, unauthenticated integration port (works local AND from
# another box). No credentials needed.
FRIGATE_URL=http://YOUR_FRIGATE_IP:5000
FRIGATE_API_PREFIX=/api

# Credentials: leave blank for the 5000/api port (it's unauthenticated by design).
# Only needed for the authenticated TLS port (https://<host>:8971/api) if you
# want the companion to require auth over an untrusted network.
# FRIGATE_USER=admin
# FRIGATE_PASSWORD=
